# --- ENVIRONNEMENT DEV ---
ENV=dev

# Configuration PostgreSQL (utilisé par l'image postgres pour initialiser)
POSTGRES_USER=amaury
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres

# Bases de données applicatives
DB_USER=amaury
DB_PASSWORD=password
DB_NAME=footballapp_db
DB_ML_NAME=footballml_db

# URLs de connexion (les hosts correspondent aux noms de services docker-compose)
DATABASE_URL=postgresql://amaury:password@db-app:5432/footballapp_db
DATABASE_ML_URL=postgresql://amaury:password@db-ml:5432/footballml_db

# URLs des Services
ML_API_URL=http://api-ml:8001
APP_API_URL=http://api-app:8000
FRONTEND_URL=http://localhost:8083

# Auth JWT
SECRET_KEY=dev-secret-key-very-weak
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Sécurité Inter-Services
SERVICE_TOKEN=dev-service-token
