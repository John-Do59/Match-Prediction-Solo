# --- ENVIRONNEMENT DEV ---
ENV=dev

# Configuration PostgreSQL (Docker)
POSTGRES_USER=amaury
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres

# Bases de données applicatives (Hôte Docker)
DB_USER=amaury
DB_PASSWORD=password
DB_NAME=footballapp_db
DB_ML_NAME=footballml_db
DB_HOST=postgres-db

DATABASE_URL=postgresql://amaury:password@postgres-db:5432/footballapp_db
DATABASE_ML_URL=postgresql://amaury:password@postgres-db:5432/footballml_db

# URLs des Services
ML_API_URL=http://api-ml:8001
APP_API_URL=http://api-app:8000
FRONTEND_URL=http://localhost:8082

# Auth JWT
SECRET_KEY=dev-secret-key-very-weak
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Sécurité Inter-Services
SERVICE_TOKEN=dev-service-token
