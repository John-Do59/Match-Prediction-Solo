# ============================================================
# Variables d'environnement — Match Prediction App
# Copie ce fichier : cp .env.example .env
# Ne committe JAMAIS le fichier .env
# ============================================================

# --- Base de données Application (utilisateurs, auth, historique) ---
# Utilisé par FastAPI_App
# En local : localhost:5432 | En Docker : postgres-db:5432
DB_USER=amaury
DB_PASSWORD=password
DB_NAME=footballapp_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres-db:5432/${DB_NAME}

# --- Base de données ML (matchs, entraînement, prédiction) ---
# Utilisé par FastAPI_ML
DB_ML_NAME=footballml_db
DATABASE_ML_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres-db:5432/${DB_ML_NAME}


# --- Authentification JWT (FastAPI_App uniquement) ---
# IMPORTANT : Cette valeur est désormais OBLIGATOIRE au démarrage.
# Générez une clé robuste : openssl rand -hex 32
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Sécurité Inter-Services ---
# Token partagé entre api-app et api-ml pour sécuriser leurs échanges.
# Générez une valeur aléatoire : openssl rand -hex 32
SERVICE_TOKEN=change-me-in-production

# --- Service d'Email (Resend) ---
# Optionnel en développement (log dans la console), requis en production.
RESEND_API_KEY=re_PLACEHOLDER_xxxxxxxx
EMAIL_FROM=noreply@votre-domaine.com
FRONTEND_URL=https://localhost:8443

# --- URL de l'API ML (appelée par FastAPI_App) ---
# En local : localhost:8001 | En Docker : api-ml:8001
ML_API_URL=http://api-ml:8001

# --- Chemins ML (relatifs à FastAPI_ML/) ---
MODEL_PATH=../Data/dataset/match_model_v1.joblib
DATASET_PATH=../Data/dataset/completed_match_dataset_final.csv
DATA_DIR=../Data/dataset
